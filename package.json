{
  "name": "pluggy-sdk",
  "version": "0.85.2",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=12.0.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.10.0",
      "onFail": "error"
    }
  },
  "scripts": {
    "test": "jest --testPathIgnorePatterns=tests/integration.test.ts",
    "test:integration": "jest --testPathPattern=integration --runInBand",
    "build": "tsc -p tsconfig.build.json",
    "prepare": "pnpm run build",
    "prettier-fix": "prettier --write \"src/**/*.ts\"",
    "lint": "pnpm run prettier-fix && eslint .",
    "lint:fix": "pnpm run lint -- --fix",
    "lint:lockfile": "pnpm install --frozen-lockfile",
    "audit:supply-chain": "pnpm audit --prod --audit-level=high && pnpm audit signatures",
    "semantic-release": "semantic-release"
  },
  "repository": "https://github.com/pluggyai/pluggy-node",
  "keywords": [
    "pluggy",
    "pluggy.ai",
    "pluggy-api",
    "aggregation",
    "pluggy-sdk",
    "open banking"
  ],
  "dependencies": {
    "got": "11.8.6",
    "jsonwebtoken": "9.0.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "8.5.4",
    "@types/node": "22.19.17",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "dotenv": "16.4.5",
    "eslint": "10.3.0",
    "globals": "17.6.0",
    "jest": "30.3.0",
    "nock": "13.5.4",
    "prettier": "1.19.1",
    "semantic-release": "25.0.3",
    "ts-jest": "29.4.9",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2"
  },
  "release": {
    "branches": [
      "+([0-9])?(.{+([0-9]),x}).x",
      "master",
      {
        "name": "beta",
        "prerelease": true
      },
      {
        "name": "alpha",
        "prerelease": true
      }
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ]
    ]
  }
}
