{
  "name": "pluggy-node-example",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.0.0",
      "onFail": "error"
    }
  },
  "scripts": {
    "preinstall": "pnpm audit && pnpm audit signatures",
    "lint:lockfile": "pnpm install --frozen-lockfile",
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "example:auth": "ts-node src/auth.ts",
    "example:mfa": "ts-node src/mfa.ts",
    "example:webhooks": "ts-node src/webhooks.ts",
    "example:investments": "ts-node src/investments.ts",
    "example:creditcards": "ts-node src/creditCards.ts",
    "example:connecttoken": "ts-node src/connectToken.ts",
    "example:payments": "ts-node src/payments.ts",
    "example:loans": "ts-node src/loans.ts",
    "example:account-statements": "ts-node src/accountStatements.ts",
    "example:payment-recipient": "ts-node src/payment-recipient.ts"
  },
  "dependencies": {
    "dotenv": "17.4.2",
    "moment": "2.30.1",
    "pluggy-sdk": "link:.."
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
