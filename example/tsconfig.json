{
  "compilerOptions": {
    "target": "ES2024",
    "module": "node20",
    "moduleResolution": "node16",
    "lib": ["ES2024"],
    "declaration": true,
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
